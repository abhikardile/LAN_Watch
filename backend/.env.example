# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/network-monitor

# Port for the Express + Socket.io server
PORT=4000

# CORS - the origin your frontend is served from
CLIENT_ORIGIN=http://localhost:5173

# Scan / ping cadence (milliseconds)
SCAN_INTERVAL_MS=45000

# Consecutive failed pings required before a device is declared "down"
# (debounces Wi-Fi sleep / one-off packet loss)
FAILURE_THRESHOLD=3

# Subnet to scan, e.g. 192.168.1.0/24. If omitted, local-devices will
# try to infer it from the machine's active network interface.
SCAN_SUBNET=

# --- Optional email alerts (leave blank to disable) ---
ALERTS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=

# Minutes a device must stay down before an email alert fires
ALERT_AFTER_MINUTES=5
